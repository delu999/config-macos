{
    "global": { "check_for_updates_on_startup": false },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "manipulators": [
                            {
                                "description": "Change caps_lock to command+control+option+shift (meta key)",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_command", "left_control", "left_option"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + 8 → {",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "8",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [
                                    {
                                        "key_code": "open_bracket",
                                        "modifiers": ["shift", "option"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + 9 → }",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "9",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [
                                    {
                                        "key_code": "close_bracket",
                                        "modifiers": ["shift", "option"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Disable cmd + h to prevent minimising an application window",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "h",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Disable cmd + m to prevent minimising an application window",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "m",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Cmd+Q to Cmd+W in Finder only",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "com.apple.finder"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "q",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [
                                    {
                                        "key_code": "w",
                                        "modifiers": ["command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + v spotlight clipboard history",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "v",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [
                                    {
                                        "hold_down_milliseconds": 200,
                                        "key_code": "spacebar",
                                        "modifiers": ["command"]
                                    },
                                    {
                                        "key_code": "4",
                                        "modifiers": ["command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + m → cmd+m, m",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "m",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [
                                    {
                                        "key_code": "m",
                                        "modifiers": ["command"]
                                    },
                                    { "key_code": "m" }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + space layer for selection",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "spacebar",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [
                                    {
                                        "set_variable": {
                                            "name": "meta_space_layer",
                                            "value": 1
                                        }
                                    }
                                ],
                                "to_after_key_up": [
                                    {
                                        "set_variable": {
                                            "name": "meta_space_layer",
                                            "value": 0
                                        }
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + space + h → select left",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "name": "meta_space_layer",
                                        "type": "variable_if",
                                        "value": 1
                                    }
                                ],
                                "from": {
                                    "key_code": "h",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_arrow",
                                        "modifiers": ["shift"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + space + l → select right",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "name": "meta_space_layer",
                                        "type": "variable_if",
                                        "value": 1
                                    }
                                ],
                                "from": {
                                    "key_code": "l",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [
                                    {
                                        "key_code": "right_arrow",
                                        "modifiers": ["shift"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + h → left arrow",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "h",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "key_code": "left_arrow" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + j → down arrow",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "j",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "key_code": "down_arrow" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + k → up arrow",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "k",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "key_code": "up_arrow" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + l → right arrow",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "l",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "key_code": "right_arrow" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + left_arrow → move Dock left",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "left_arrow",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "shell_command": "osascript -e 'tell application \"System Events\" to tell dock preferences to set screen edge to left' -e 'tell application \"System Events\" to tell dock preferences to set autohide to false'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + up_arrow → hide Dock",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "up_arrow",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "shell_command": "osascript -e 'tell application \"System Events\" to tell dock preferences to set autohide to true'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + down_arrow → move Dock bottom",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "down_arrow",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "shell_command": "osascript -e 'tell application \"System Events\" to tell dock preferences to set screen edge to bottom' -e 'tell application \"System Events\" to tell dock preferences to set autohide to false'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "meta + right_arrow → move Dock right",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "right_arrow",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "shell_command": "osascript -e 'tell application \"System Events\" to tell dock preferences to set screen edge to right' -e 'tell application \"System Events\" to tell dock preferences to set autohide to false'" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "devices": [
                {
                    "identifiers": {
                        "is_pointing_device": true,
                        "product_id": 45105,
                        "vendor_id": 1133
                    },
                    "ignore": false,
                    "mouse_flip_vertical_wheel": true
                },
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "is_pointing_device": true,
                        "product_id": 361,
                        "vendor_id": 9494
                    },
                    "ignore": false,
                    "mouse_flip_vertical_wheel": true
                },
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "product_id": 641,
                        "vendor_id": 1452
                    },
                    "manipulate_caps_lock_led": false
                }
            ],
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": {
                "indicate_sticky_modifier_keys_state": false,
                "keyboard_type_v2": "ansi"
            }
        }
    ]
}
